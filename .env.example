# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# MCP gateways (Zaiserver for Zoho; Gmail and Calendly are separate gateways)
ZAISERVER_MCP_URL=
GMAIL_MCP_URL=
CALENDLY_MCP_URL=

# Auth (V1 is a sign-in dropdown over this list)
SESSION_SECRET=change-me-to-a-32-character-random-string-please
ALLOWED_USERS=[{"email":"eric@zaiinstitute.org","name":"Eric","zoho_user_id":"REPLACE_ME"}]

# Ports
PORT_FRONTEND=5173
PORT_BACKEND=3001

# When true: real Anthropic, fake Zoho fixtures, console-printed Gmail.
# Lets you build and demo without touching production Zoho.
TEST_MODE=true
